package com.example.fiveme

import androidx.compose.foundation.layout.fillMaxSize
import androidx.compose.foundation.layout.safeDrawingPadding
import androidx.compose.runtime.Composable
import androidx.compose.ui.Modifier
import androidx.lifecycle.viewmodel.compose.viewModel
import androidx.navigation3.runtime.entryProvider
import androidx.navigation3.runtime.rememberNavBackStack
import androidx.navigation3.ui.NavDisplay
import com.example.fiveme.ui.FiveMeViewModel
import com.example.fiveme.ui.screens.*

import androidx.navigation3.runtime.NavKey

@Composable
fun MainNavigation() {
  // Use Feed as the starting entry destination
  val backStack = rememberNavBackStack(Feed)
  val app = FiveMeApplication.instance
  val viewModel: FiveMeViewModel = viewModel { FiveMeViewModel(app.repository) }

  NavDisplay(
    backStack = backStack,
    onBack = { backStack.removeLastOrNull() },
    entryProvider =
      entryProvider {
        entry<Feed> {
          FeedScreen(
            viewModel = viewModel,
            onNavigate = { key -> backStack.add(key as NavKey) }
          )
        }
        entry<GiveFive> { key ->
          GiveFiveScreen(
            parentHighFiveId = key.parentHighFiveId,
            viewModel = viewModel,
            onBack = { backStack.removeLastOrNull() }
          )
        }
        entry<Notifications> {
          NotificationsScreen(
            viewModel = viewModel,
            onBack = { backStack.removeLastOrNull() }
          )
        }
        entry<Profile> {
          ProfileScreen(
            viewModel = viewModel,
            onBack = { backStack.removeLastOrNull() }
          )
        }
        entry<ChainView> { key ->
          ChainViewScreen(
            highFiveId = key.highFiveId,
            viewModel = viewModel,
            onBack = { backStack.removeLastOrNull() }
          )
        }
        entry<Sandbox> {
          SandboxScreen(
            viewModel = viewModel,
            onBack = { backStack.removeLastOrNull() }
          )
        }
      },
    modifier = Modifier.fillMaxSize().safeDrawingPadding()
  )
}
